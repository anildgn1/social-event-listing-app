<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Başlangıç Tarihi -->
        <EditText
            android:id="@+id/startDateEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Başlangıç Tarihi (YYYY-MM-DD)" />

        <!-- Bitiş Tarihi -->
        <EditText
            android:id="@+id/endDateEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bitiş Tarihi (YYYY-MM-DD)"
            android:layout_marginTop="8dp" />

        <!-- Minimum Kapasite -->
        <EditText
            android:id="@+id/minCapacityEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Minimum Kapasite"
            android:inputType="number"
            android:layout_marginTop="8dp" />

        <!-- Maksimum Kapasite -->
        <EditText
            android:id="@+id/maxCapacityEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Maksimum Kapasite"
            android:inputType="number"
            android:layout_marginTop="8dp" />

        <!-- Şehir Spinner -->
        <Spinner
            android:id="@+id/citySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:spinnerMode="dropdown" />

        <!-- İlçe Spinner -->
        <Spinner
            android:id="@+id/districtSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:spinnerMode="dropdown"
            android:visibility="gone" /> <!-- Başlangıçta gizli -->

        <!-- Etkinlik Türü -->
        <Spinner
            android:id="@+id/eventTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:spinnerMode="dropdown" />

        <!-- Ödeme Türü -->
        <Spinner
            android:id="@+id/paymentTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:spinnerMode="dropdown" />

        <!-- Filtreyi Uygula Butonu -->
        <Button
            android:id="@+id/applyFilterButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filtreyi Uygula"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/clearFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filtreleri Temizle"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:backgroundTint="@color/primaryColor"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>
</ScrollView>
