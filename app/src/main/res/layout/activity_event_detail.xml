<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3ED"
    android:padding="20dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Etkinlik Görseli -->
                <ImageView
                    android:id="@+id/eventImageView"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/image_rounded_bg"
                    android:clipToOutline="true"
                    android:contentDescription="@string/event_image_desc"
                    android:scaleType="centerCrop" />

                <!-- Başlık -->
                <TextView
                    android:id="@+id/eventTitleTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Event Title"
                    android:textColor="#333333"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Lokasyon -->
                <TextView
                    android:id="@+id/eventCityTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="İstanbul"
                    android:textColor="#777777"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/eventDistrictTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Beşiktaş"
                    android:textColor="#777777"
                    android:textSize="15sp" />

                <!-- Tarih -->
                <TextView
                    android:id="@+id/eventDateTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="15.12.2024"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <!-- Açıklama -->
                <TextView
                    android:id="@+id/eventDescriptionTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Event Description here..."
                    android:textColor="#444444"
                    android:textSize="15sp" />

                <!-- Kapasite -->
                <TextView
                    android:id="@+id/eventCapacityTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Capacity: 50"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Harita -->
                <com.google.android.gms.maps.MapView
                    android:id="@+id/eventMapView"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/image_rounded_bg"
                    android:clipToOutline="true"
                    android:contentDescription="@string/event_map_desc" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>
